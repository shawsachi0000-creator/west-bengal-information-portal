<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>India Information Portal</title>

<meta name="description"
content="India Information Portal - Government Schemes, Jobs, News, Education, Health, Tourism, Weather and AI Assistant">

<meta name="keywords"
content="India, Government, Jobs, News, Education, Health, Tourism">

<meta name="theme-color" content="#0d6efd">

<link rel="stylesheet" href="style.css">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

</head>

<body>

<header class="header">

<div class="logo">
<i class="fa-solid fa-landmark"></i>
<span>India Information Portal</span>
</div>

<nav id="navMenu">

<a href="#home">Home</a>

<a href="#schemes">Schemes</a>

<a href="#jobs">Jobs</a>

<a href="#news">News</a>

<a href="#education">Education</a>

<a href="#health">Health</a>

<a href="#tourism">Tourism</a>

<a href="#contact">Contact</a>

</nav>

<div class="header-buttons">

<button id="searchBtn">
<i class="fa-solid fa-magnifying-glass"></i>
</button>

<button id="darkBtn">
<i class="fa-solid fa-moon"></i>
</button>

<button id="menuBtn">
<i class="fa-solid fa-bars"></i>
</button>

</div>

</header>

<section class="hero" id="home">

<div class="hero-content">

<h1>
Welcome to India Information Portal
</h1>

<p>

Government Services, Jobs, News, Education,
Health, Tourism and AI Assistant in one place.

</p>

<div class="hero-buttons">

<button id="exploreBtn">
Explore Now
</button>

<button id="aiBtn">
AI Assistant
</button>

</div>

</div>

</section>

<section class="search-section">

<input
type="text"
id="searchBox"
placeholder="Search anything...">

<button id="searchNow">

<i class="fa-solid fa-search"></i>

</button>

</section>

<!-- Part-2 continues -->
<!-- =========================
Government Schemes
========================= -->

<section id="schemes" class="section">

<div class="section-title">

<h2>Government Schemes</h2>

<p>Latest Central & State Government Schemes</p>

</div>

<div class="card-container">

<div class="card">
<i class="fa-solid fa-building-columns"></i>
<h3>PM Kisan</h3>
<p>Financial support for farmers.</p>
<a href="#">Read More</a>
</div>

<div class="card">
<i class="fa-solid fa-house"></i>
<h3>PM Awas Yojana</h3>
<p>Housing scheme for eligible families.</p>
<a href="#">Read More</a>
</div>

<div class="card">
<i class="fa-solid fa-user-doctor"></i>
<h3>Ayushman Bharat</h3>
<p>Free health insurance benefits.</p>
<a href="#">Read More</a>
</div>

<div class="card">
<i class="fa-solid fa-graduation-cap"></i>
<h3>Scholarships</h3>
<p>Central & State scholarship updates.</p>
<a href="#">Read More</a>
</div>

</div>

</section>

<!-- =========================
Jobs
========================= -->

<section id="jobs" class="section">

<div class="section-title">

<h2>Latest Jobs</h2>

<p>Government & Private Jobs</p>

</div>

<div class="card-container">

<div class="card">
<h3>SSC Recruitment</h3>
<p>Latest SSC notifications.</p>
<button class="details-btn">Details</button>
</div>

<div class="card">
<h3>Railway Jobs</h3>
<p>RRB recruitment updates.</p>
<button class="details-btn">Details</button>
</div>

<div class="card">
<h3>Bank Jobs</h3>
<p>SBI, IBPS, RBI recruitment.</p>
<button class="details-btn">Details</button>
</div>

<div class="card">
<h3>Private Jobs</h3>
<p>Top company openings.</p>
<button class="details-btn">Details</button>
</div>

</div>

</section>

<!-- =========================
Latest News
========================= -->

<section id="news" class="section">

<div class="section-title">

<h2>Latest News</h2>

<p>Trending India News</p>

</div>

<div class="news-box">

<marquee behavior="scroll" direction="left">

Breaking News • Government Updates • Jobs • Education • Technology • Sports • Entertainment

</marquee>

</div>

</section>

<!-- Part-3 Continues -->
<!-- =========================
Education
========================= -->

<section id="education" class="section">

<div class="section-title">
<h2>Education</h2>
<p>Study Materials & Exam Updates</p>
</div>

<div class="card-container">

<div class="card">
<i class="fa-solid fa-book"></i>
<h3>School</h3>
<p>Class 1–12 study resources.</p>
<button class="details-btn">Open</button>
</div>

<div class="card">
<i class="fa-solid fa-graduation-cap"></i>
<h3>College</h3>
<p>University notices & syllabus.</p>
<button class="details-btn">Open</button>
</div>

<div class="card">
<i class="fa-solid fa-file-lines"></i>
<h3>Previous Papers</h3>
<p>Download question papers.</p>
<button class="details-btn">Open</button>
</div>

<div class="card">
<i class="fa-solid fa-laptop-code"></i>
<h3>Online Courses</h3>
<p>Free learning resources.</p>
<button class="details-btn">Open</button>
</div>

</div>

</section>

<!-- =========================
Health
========================= -->

<section id="health" class="section">

<div class="section-title">
<h2>Health</h2>
<p>Healthcare Services</p>
</div>

<div class="card-container">

<div class="card">
<i class="fa-solid fa-hospital"></i>
<h3>Hospitals</h3>
<p>Government & private hospitals.</p>
<button class="details-btn">View</button>
</div>

<div class="card">
<i class="fa-solid fa-user-doctor"></i>
<h3>Doctors</h3>
<p>Find specialist doctors.</p>
<button class="details-btn">View</button>
</div>

<div class="card">
<i class="fa-solid fa-truck-medical"></i>
<h3>Emergency</h3>
<p>Ambulance & emergency help.</p>
<button class="details-btn">View</button>
</div>

<div class="card">
<i class="fa-solid fa-pills"></i>
<h3>Medicine</h3>
<p>Medicine information.</p>
<button class="details-btn">View</button>
</div>

</div>

</section>

<!-- =========================
Tourism
========================= -->

<section id="tourism" class="section">

<div class="section-title">
<h2>Tourism</h2>
<p>Explore Incredible India</p>
</div>

<div class="card-container">

<div class="card">
<i class="fa-solid fa-mountain"></i>
<h3>Hill Stations</h3>
<p>Beautiful mountain destinations.</p>
</div>

<div class="card">
<i class="fa-solid fa-umbrella-beach"></i>
<h3>Beaches</h3>
<p>Top beaches in India.</p>
</div>

<div class="card">
<i class="fa-solid fa-landmark"></i>
<h3>Historical Places</h3>
<p>World famous monuments.</p>
</div>

<div class="card">
<i class="fa-solid fa-tree"></i>
<h3>National Parks</h3>
<p>Wildlife & nature destinations.</p>
</div>

</div>

</section>

<!-- Part-4 Continues -->
  <!-- =========================
Weather
========================= -->

<section id="weather" class="section">

<div class="section-title">
<h2>Weather</h2>
<p>Current Weather Information</p>
</div>

<div class="weather-card">

<h3 id="cityName">New Delhi</h3>

<h1 id="temperature">30°C</h1>

<p id="weatherStatus">Sunny</p>

<button id="refreshWeather">
Refresh Weather
</button>

</div>

</section>

<!-- =========================
AI Assistant
========================= -->

<section id="ai" class="section">

<div class="section-title">

<h2>AI Assistant</h2>

<p>Ask anything instantly</p>

</div>

<div class="ai-box">

<input
type="text"
id="aiInput"
placeholder="Ask your question...">

<button id="askAI">

<i class="fa-solid fa-paper-plane"></i>

Ask

</button>

<div id="aiAnswer">

AI response will appear here...

</div>

</div>

</section>

<!-- =========================
Contact
========================= -->

<section id="contact" class="section">

<div class="section-title">

<h2>Contact Us</h2>

<p>Send us your feedback</p>

</div>

<form id="contactForm">

<input
type="text"
placeholder="Your Name"
required>

<input
type="email"
placeholder="Your Email"
required>

<textarea
placeholder="Write your message..."
rows="5"
required></textarea>

<button type="submit">

Send Message

</button>

</form>

</section>

<!-- =========================
Scroll To Top
========================= -->

<button id="scrollTop">

<i class="fa-solid fa-arrow-up"></i>

</button>

<!-- Part-5 Continues -->
  <!-- =========================
Quick Services
========================= -->

<section id="services" class="section">

<div class="section-title">
<h2>Quick Services</h2>
<p>Important Government Services</p>
</div>

<div class="card-container">

<div class="card">
<i class="fa-solid fa-id-card"></i>
<h3>Aadhaar</h3>
<p>UIDAI Services</p>
<button class="service-btn">Open</button>
</div>

<div class="card">
<i class="fa-solid fa-address-card"></i>
<h3>PAN Card</h3>
<p>Income Tax Services</p>
<button class="service-btn">Open</button>
</div>

<div class="card">
<i class="fa-solid fa-passport"></i>
<h3>Passport</h3>
<p>Passport Seva</p>
<button class="service-btn">Open</button>
</div>

<div class="card">
<i class="fa-solid fa-car"></i>
<h3>Driving Licence</h3>
<p>Parivahan Services</p>
<button class="service-btn">Open</button>
</div>

<div class="card">
<i class="fa-solid fa-building-columns"></i>
<h3>Banking</h3>
<p>Important Banking Links</p>
<button class="service-btn">Open</button>
</div>

<div class="card">
<i class="fa-solid fa-file-signature"></i>
<h3>Certificates</h3>
<p>Birth, Caste & Income Certificate</p>
<button class="service-btn">Open</button>
</div>

</div>

</section>

<!-- =========================
Settings Panel
========================= -->

<section id="settings" class="section">

<div class="section-title">
<h2>Settings</h2>
<p>Customize Your Experience</p>
</div>

<div class="settings-box">

<label>
<input type="checkbox" id="darkModeSwitch">
Enable Dark Mode
</label>

<label>
<input type="checkbox" id="notificationSwitch">
Enable Notifications
</label>

<label>
<input type="checkbox" id="animationSwitch" checked>
Enable Animations
</label>

</div>

</section>

<!-- =========================
Footer
========================= -->

<footer>

<div class="footer-content">

<h2>India Information Portal</h2>

<p>
One Platform for Government Services, Jobs,
News, Education, Health and Tourism.
</p>

<div class="footer-links">

<a href="#home">Home</a>
<a href="#schemes">Schemes</a>
<a href="#jobs">Jobs</a>
<a href="#news">News</a>
<a href="#contact">Contact</a>

</div>

<p class="copyright">

© 2026 India Information Portal.
All Rights Reserved.

</p>

</div>

</footer>

<script src="script.js"></script>

</body>
</html>
